# @modelcontextprotocol/ext-apps (devDependency, used only to rebuild the MCP
# card-picker widget via `npm run build:widget`) declares a peer of
# @modelcontextprotocol/sdk ^1.29, while mcp-handler pins the sdk to 1.26.
# The widget bundle is prebuilt and committed (lib/mcp/card-picker-html.ts), so
# this peer mismatch is inert at runtime. Accept it so installs succeed on
# Vercel/CI just as they do locally.
legacy-peer-deps=true
